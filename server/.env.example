# Salin ke .env untuk development lokal
PORT=5000
NODE_ENV=development

# PostgreSQL (lokal atau Render External Database URL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/litepos

# JWT — WAJIB ganti string panjang acak di production
JWT_SECRET=ubah-dengan-string-rahasia-minimal-32-karakter

# URL frontend (Vercel) — untuk CORS production
# Contoh: https://litepos.vercel.app
CLIENT_URL=http://localhost:5173

# Opsional: beberapa origin dipisah koma (preview Vercel, dll.)
# CORS_ORIGINS=https://litepos.vercel.app,https://litepos-git-main-username.vercel.app
