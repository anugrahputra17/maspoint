# Salin ke .env untuk development lokal
PORT=5000
NODE_ENV=development

# Supabase (Choreo/cloud) — Transaction pooler port 6543 (hindari ENETUNREACH IPv6)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
# DATABASE_SSL=true
DATABASE_URL=postgres://postgres:postgres@localhost:5432/litepos
DATABASE_SSL=false

# JWT — WAJIB ganti string panjang acak di production
JWT_SECRET=ubah-dengan-string-rahasia-minimal-32-karakter

# URL frontend — untuk CORS production
CLIENT_URL=http://localhost:5173

# Choreo Docker: set PORT=8080 (sesuai server/.choreo/component.yaml)
# PORT=8080

# Opsional: beberapa origin dipisah koma (preview Vercel, dll.)
# CORS_ORIGINS=https://litepos.vercel.app
