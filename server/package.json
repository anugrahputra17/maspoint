{
  "name": "litepos-server",
  "version": "1.0.0",
  "description": "LitePOS Backend API",
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
